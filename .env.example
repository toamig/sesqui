# Online play (cross-device) configuration.
#
# Copy this file to .env.local and fill in your Supabase project's PUBLIC keys
# to enable cross-device online play. Without these, the app falls back to
# local-test mode (rooms only connect between tabs of the same browser).
#
# Both values are safe to be public (the anon key is designed to ship in client
# code). Do NOT put the service_role key here -- it is secret and never needed.
#
# .env.local is gitignored. For CI/Pages deploys, set these as repo secrets
# named VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY instead.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
